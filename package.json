{
  "name": "svarog-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.app.json --noEmit && vite build",
    "build:staging": "vue-tsc -p tsconfig.app.json --noEmit && vite build --mode staging",
    "build:production": "vue-tsc -p tsconfig.app.json --noEmit && vite build --mode production",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:open-android": "cap open android",
    "cap:build": "npm run build && cap sync",
    "android:apk": "npm run build && cap sync android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.0",
    "@capacitor/app": "^7.1.0",
    "@capacitor/core": "^7.4.0",
    "@capacitor/status-bar": "^7.0.3",
    "@trpc/client": "^11.7.1",
    "pinia": "^3.0.3",
    "svarog-design": "file:../svarog-design",
    "three": "^0.181.0",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.9.1",
    "sass": "^1.99.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.0",
    "vite": "^7.1.0",
    "vue-tsc": "^3.1.0"
  }
}
